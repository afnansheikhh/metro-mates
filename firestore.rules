rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any authenticated user can read; only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Sessions: any authenticated user can read; only owner can create/update
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Likes: any authenticated user can read; only sender can create
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.fromUserId == request.auth.uid;
    }

    // Matches: only participants can read/write; any authenticated can create
    match /matches/{matchId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null;
    }

    // Messages: participants can read; only sender can create
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
    }

    // Reports: create only by reporter
    match /reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
    }
  }
}
